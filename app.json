{
  "expo": {
    "name": "Smart Poultry Farm Manager",
    "slug": "smart-poultry-farm-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000814"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mohgemy94.smartpoultry"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1B2A"
      },
      "package": "com.mohgemy94.smartpoultry",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./public/favicon.svg"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow Smart Poultry Farm Manager to access your location.",
          "locationWhenInUsePermission": "Allow Smart Poultry Farm Manager to access your location."
        }
      ]
    ]
  }
}
