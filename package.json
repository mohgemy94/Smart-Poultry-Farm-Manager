{
  "name": "smart-poultry-farm-manager",
  "version": "1.0.0",
  "private": true,
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "cap:sync": "npx cap sync",
    "cap:add:android": "npx cap add android",
    "build:android": "npm run build && npx cap add android || true && npx cap sync android",
    "clean": "rm -rf dist android/build ios/build",
    "dev:server": "tsx server.ts"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/toast": "^6.0.0",
    "@google/genai": "^1.30.2",
    "@tailwindcss/vite": "^4.0.9",
    "@types/cors": "^2.8.19",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase": "^11.4.0",
    "lucide-react": "^0.477.0",
    "motion": "^12.4.10",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.2",
    "tsx": "^4.19.3",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@capacitor/cli": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.9",
    "@types/react": "~18.3.12",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.9",
    "typescript": "~5.3.3"
  }
}
